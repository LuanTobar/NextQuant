# ── Multi-Market Configuration ───────────────────────────────────────
# JSON array: each entry is { exchange, provider, symbols }
# Providers: alpaca (US only), finnhub (international), mock (fallback)
# Example with all 4 markets:
# MARKETS=[{"exchange":"US","provider":"alpaca","symbols":["AAPL","GOOGL","MSFT","AMZN","TSLA"]},{"exchange":"LSE","provider":"finnhub","symbols":["VOD.L","BP.L","HSBA.L","AZN.L","SHEL.L"]},{"exchange":"BME","provider":"finnhub","symbols":["SAN.MC","TEF.MC","IBE.MC","ITX.MC","BBVA.MC"]},{"exchange":"TSE","provider":"finnhub","symbols":["7203.T","6758.T","9984.T","8306.T","6861.T"]}]

# ── Legacy single-market (fallback if MARKETS not set) ───────────────
# Options: mock | alpaca | finnhub
MARKET_DATA_SOURCE=mock
SYMBOLS=AAPL,GOOGL,MSFT,AMZN,TSLA

# ── Alpaca Markets (free paper trading — US equities) ────────────────
# Sign up at: https://alpaca.markets
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_WS_URL=wss://stream.data.alpaca.markets/v2/iex

# ── Finnhub (free tier — international markets) ─────────────────────
# Sign up at: https://finnhub.io
FINNHUB_API_KEY=
FINNHUB_WS_URL=wss://ws.finnhub.io

# ── Claude API for chat (Anthropic) ──────────────────────────────────
# Sign up at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── Service URLs (for local development outside Docker) ──────────────
NATS_URL=nats://localhost:4222
QUESTDB_URL=http://localhost:9010

# ── Rust Engine ──────────────────────────────────────────────────────
TICK_INTERVAL_MS=1000
SNAPSHOT_INTERVAL_MS=5000
BATCH_SIZE=10

# ── Python ML ────────────────────────────────────────────────────────
MODEL_RETRAIN_INTERVAL=100
CAUSAL_LOOKBACK=20
LOG_LEVEL=INFO

# ── Stripe Billing ───────────────────────────────────────────
# Sign up at: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Alerting (optional) ──────────────────────────────────────────────
# Discord/Slack/generic HTTP webhook for critical trading alerts.
# Leave empty to disable. Format: https://discord.com/api/webhooks/...
ALERT_WEBHOOK_URL=

# ── Logging ──────────────────────────────────────────────────────────
RUST_LOG=info
